{
	"appId": "com.arc.arctivate",
	"appName": "Arctivate",
	"webDir": "out",
	"server": {
		"androidScheme": "https"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"launchAutoHide": true,
			"backgroundColor": "#0a0a0a",
			"showSpinner": false
		},
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#0a0a0a"
		},
		"Keyboard": {
			"resize": "body",
			"resizeOnFullScreen": true
		}
	},
	"ios": {
		"contentInset": "automatic",
		"preferredContentMode": "mobile"
	},
	"android": {
		"backgroundColor": "#0a0a0a"
	},
	"packageClassList": [
		"AppPlugin",
		"CAPBrowserPlugin",
		"HapticsPlugin",
		"KeyboardPlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin"
	]
}
